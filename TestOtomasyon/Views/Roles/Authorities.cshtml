@model TestOtomasyon.Models.RoleAuthoritiesViewModel
@using TestOtomasyon.Helpers

@{
    ViewData["Title"] = L["Role.PageTitleAuth"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h4>⚡ @L["Role.AuthHeading"] — <span class="text-primary">@Model.RoleName</span></h4>
        <p class="text-muted">@L["Role.AuthIntro"]</p>
        <hr />

        <form asp-action="Authorities" asp-route-id="@Model.RoleId" method="post">
            @Html.AntiForgeryToken()

            <div class="row">
                @foreach (var auth in Model.Authorities)
                {
                    <div class="col-md-6 mb-2">
                        <div class="form-check p-3 border rounded">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="selectedAuthorities"
                                   value="@auth.Id"
                                   id="auth_@auth.Id"
                                   @(auth.IsAssigned ? "checked" : "") />
                            <label class="form-check-label fw-bold" for="auth_@auth.Id">
                                @AuthorityNameHelper.GetDisplayName(auth.Name)
                                <div class="text-muted small mt-1" style="font-weight: normal;">
                                    <code>@auth.Name</code>
                                </div>
                            </label>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success">💾 @L["Common.Save"]</button>
                <a asp-action="Index" class="btn btn-secondary">@L["Common.Cancel"]</a>
                <button type="button" class="btn btn-outline-info ms-auto" onclick="toggleAll(true)">
                    ✓ @L["Role.SelectAll"]
                </button>
                <button type="button" class="btn btn-outline-warning" onclick="toggleAll(false)">
                    ✗ @L["Role.DeselectAll"]
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleAll(checked) {
            document.querySelectorAll('input[name="selectedAuthorities"]').forEach(cb => {
                cb.checked = checked;
            });
        }
    </script>
}
