@model TestOtomasyon.Entities.Department

@{
    ViewData["Title"] = L["Dept.PageTitleCreate"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h4>➕ @L["Dept.HeadingCreate"]</h4>
        <hr />

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">@L["Dept.Name"]</label>
                <input asp-for="Name" class="form-control" autofocus required />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success">💾 @L["Common.Save"]</button>
                <a asp-action="Index" class="btn btn-secondary">@L["Common.Cancel"]</a>
            </div>
        </form>
    </div>
</div>
