@model TestOtomasyon.Models.TaskProposeViewModel

@{
    ViewData["Title"] = L["Task.PageTitlePropose"].Value;
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h4>📩 @L["Task.HeadingPropose"]</h4>
        <p class="text-muted">@L["Task.ProposeInfo"]</p>
        <hr />

        <form asp-action="Propose" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" autofocus required placeholder="@L["Task.ProposeTitlePh"]" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5" required
                          placeholder="@L["Task.ProposeDescPh"]"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="alert alert-info small">
                💡 @L["Task.ProposeNote"]
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">📤 @L["Task.SubmitApproval"]</button>
                <a asp-action="MyTasks" class="btn btn-secondary">@L["Common.Cancel"]</a>
            </div>
        </form>
    </div>
</div>
